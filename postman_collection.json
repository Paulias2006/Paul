{
  "info": {
    "name": "AlitogoPay API v2.0",
    "description": "Collection des endpoints API AlitogoPay avec MongoDB",
    "version": "2.0.0",
    "contact": {
      "name": "AlitogoPay Team"
    }
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:4001",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "shopId",
      "value": "",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"user@example.com\", \"phone\": \"+226XXXXXXXX\", \"fullName\": \"John Doe\", \"password\": \"SecurePass123\"}"
            },
            "url": "{{base_url}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"user@example.com\", \"password\": \"SecurePass123\"}"
            },
            "url": "{{base_url}}/api/auth/login"
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "url": "{{base_url}}/api/auth/me"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\": \"{{refreshToken}}\"}"
            },
            "url": "{{base_url}}/api/auth/refresh"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "url": "{{base_url}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Update User Profile",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"fullName\": \"New Name\", \"avatar\": \"https://example.com/avatar.jpg\"}"
            },
            "url": "{{base_url}}/api/users/{{userId}}"
          }
        },
        {
          "name": "Get User Transactions",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "url": "{{base_url}}/api/users/{{userId}}/transactions?limit=50&skip=0"
          }
        },
        {
          "name": "Get User Wallet",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "url": "{{base_url}}/api/users/{{userId}}/wallet"
          }
        }
      ]
    },
    {
      "name": "Shops",
      "item": [
        {
          "name": "List Shops",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/shops?limit=50&skip=0&category=electronics"
          }
        },
        {
          "name": "Get Shop",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/shops/{{shopId}}"
          }
        },
        {
          "name": "Get Shop Products",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/shops/{{shopId}}/products?limit=50"
          }
        },
        {
          "name": "Create Shop",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Ma Boutique\", \"description\": \"Description\", \"category\": \"electronics\", \"phone\": \"+226XXXXXXXX\", \"address\": \"Ouagadougou\"}"
            },
            "url": "{{base_url}}/api/shops"
          }
        },
        {
          "name": "Update Shop",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Nouveau Nom\", \"description\": \"Nouvelle description\"}"
            },
            "url": "{{base_url}}/api/shops/{{shopId}}"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products?limit=50&skip=0&category=electronics"
          }
        },
        {
          "name": "Get Product",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products/{{productId}}"
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"iPhone 13\", \"description\": \"Smartphone\", \"price\": 450000, \"category\": \"Phones\", \"shopId\": \"{{shopId}}\", \"stock\": 5}"
            },
            "url": "{{base_url}}/api/products"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Initiate Payment",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"order_id\": 123, \"client_phone\": \"+226XXXXXXXX\", \"amount\": 15000, \"network\": \"mtn\", \"description\": \"Paiement commande\"}"
            },
            "url": "{{base_url}}/api/pay/initiate"
          }
        },
        {
          "name": "Check Payment Status",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"identifier\": \"ATG-1234567890-5678\"}"
            },
            "url": "{{base_url}}/api/pay/status"
          }
        }
      ]
    }
  ]
}
