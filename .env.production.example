# Production environment variables for AlitogoPay backend
# Copy this file to .env in the backend folder and fill in the real values.

NODE_ENV=production
PORT=4001

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<DB_USER>:<DB_PASSWORD>@cluster0.kqn5p5f.mongodb.net/alitogopay?retryWrites=true&w=majority

# JWT secrets
JWT_SECRET=replace_with_a_strong_random_secret
JWT_REFRESH_SECRET=replace_with_a_strong_random_secret
ADMIN_CREATE_USER_KEY=same_secret_as_weeshop_ALITOGOPAY_ADMIN_KEY

# Email service: gmail, smtp, or sendgrid
EMAIL_SERVICE=gmail
EMAIL_USER=youremail@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password
# EMAIL_PASSWORD=your_smtp_password
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
# SENDGRID_API_KEY=your_sendgrid_api_key

# Optional admin/contact email
ADMIN_EMAIL=admin@yourdomain.com

# YAS / TMoney direct collect and payout configuration
YAS_COLLECT_URL=https://provider.example/yas/collect
YAS_PAYOUT_URL=https://provider.example/yas/payout
YAS_STATUS_URL=https://provider.example/yas/status
YAS_MERCHANT_ID=your_yas_merchant_id
YAS_API_KEY=your_yas_api_key_if_used
YAS_CLIENT_ID=your_yas_client_id_if_used
YAS_CLIENT_SECRET=your_yas_client_secret_if_used
YAS_API_AUTH=Bearer your_shared_yas_token_if_used
YAS_COLLECT_AUTH=Bearer your_collect_token_if_separate
YAS_PAYOUT_AUTH=Bearer your_payout_token_if_separate
YAS_STATUS_AUTH=Bearer your_status_token_if_separate
YAS_WEBHOOK_SECRET=your_yas_webhook_secret_if_provider_signs_callbacks

# Legacy PayGate configuration, keep only if older flows still need it
PAYGATE_AUTH_TOKEN=your_paygate_auth_token
PAYGATE_WEBHOOK_SECRET=your_webhook_secret
PAYGATE_CALLBACK_SECRET=your_callback_secret
PAYGATE_ALLOW_UNSIGNED_CALLBACK=false
PAYGATE_STATUS_V1_URL=https://paygateglobal.com/api/v1/status
PAYGATE_STATUS_V2_URL=https://paygateglobal.com/api/v2/status
PAYGATE_PAYOUT_URL=https://paygateglobal.com/api/v1/cashout
PAYGATE_PAYOUT_ENABLED=true
PAYGATE_PAYOUT_NETWORK=FLOOZ
PAYGATE_RETURN_URL=https://weeshop.onrender.com/payment-return

# Weeshop / Alitogoshop sync URLs
WEEDELIVRED_SYNC_SECRET=your_sync_secret
WEESHOP_WEEDELIVRED_PAYMENT_SYNC_URL=https://weeshop.onrender.com/api/paygate/weedelivred-sync
WEESHOP_WEEDELIVRED_PAYOUT_SYNC_URL=https://weeshop.onrender.com/api/paygate/weedelivred-payout-sync
WEESHOP_WEEDELIVRED_ORDER_VERIFY_URL=https://weeshop.onrender.com/api/paygate/weedelivred-verify-order
WEESHOP_WEEDELIVRED_VERIFY_ORDER_URL=https://weeshop.onrender.com/api/paygate/weedelivred-verify-order
WEESHOP_WEEDELIVRED_DELIVERY_SYNC_URL=https://weeshop.onrender.com/api/paygate/weedelivred-delivery-sync
WEESHOP_PAYOUT_SYNC_URL=https://weeshop.onrender.com/api/paygate/weedelivred-payout-sync
WEESHOP_PAYMENT_SYNC_URL=https://weeshop.onrender.com/api/paygate/weedelivred-sync
ALITOGOSHOP_PAYOUT_SYNC_URL=https://alitogoshop.onrender.com/api_payout_sync.php
ALITOGOSHOP_SYNC_URL=https://alitogoshop.onrender.com/api_payout_sync.php
ALITOGOSHOP_URL=https://alitogoshop.onrender.com
ALITOGOSHOP_API_KEY=your_alitogoshop_api_key

# Self URLs
SELF_BASE_URL=https://weedelivred.onrender.com
WITHDRAW_CALLBACK_URL=https://weedelivred.onrender.com/api/webhook/withdraw

# Frontend URL for password reset links
FRONTEND_URL=https://weeshop.onrender.com

# CORS origin for browser clients
CORS_ORIGIN=https://weeshop.onrender.com,https://weedelivred.onrender.com,https://alitogopay.onrender.com

# Optional security and platform values
QR_SCAN_SECRET=your_qr_scan_secret
PLATFORM_USER_ID=optional_platform_user_id
FIREBASE_PROJECT_ID=weeshop-3fd8a
FIREBASE_SERVICE_ACCOUNT_JSON=your_firebase_service_account_json_or_base64
# Legacy FCM_SERVER_KEY is no longer required when FIREBASE_SERVICE_ACCOUNT_JSON is set.
FCM_SERVER_KEY=
